<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Bienvenida</title>
  <link rel="stylesheet" href="/css/formStyles.css">
</head>
<body>

  <form>
    <h2>Bienvenido, <%= usuario.nombre %></h2>

    <p class="texto-login">
      Has iniciado sesión correctamente.
    </p>

    <p class="texto-login">
      Correo: <strong><%= usuario.correo %></strong>
    </p>

    <div class="btnContainer">
      <a href="/logout" class="submit" style="text-align:center; text-decoration:none;">
        Cerrar sesión
      </a>
    </div>
  </form>

</body>
</html>